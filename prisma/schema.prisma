generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  category    String
  priceMin    Int
  priceMax    Int
  duration    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}