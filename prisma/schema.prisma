generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  category    String
  priceMin    Int
  priceMax    Int
  duration    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  visitServices VisitService[]
}
model Staff {
  id        String   @id @default(uuid())
  name      String
  role      String   @default("helper")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  queueEntries QueueEntry[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  language  String   @default("ar")
  createdAt DateTime @default(now())

  queueEntries QueueEntry[]
}

model QueueEntry {
  id          String   @id @default(uuid())
  status      String   @default("waiting")
  notes       String?
  joinedAt    DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  staffId     String?
  staff       Staff?   @relation(fields: [staffId], references: [id])

  visitServices VisitService[]

  durationOverride Int?

  createdAt   DateTime @default(now())
}
model VisitService {
  id           String   @id @default(uuid())
  priceCharged Int?

  queueEntryId String
  queueEntry   QueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)

  serviceId    String
  service      Service    @relation(fields: [serviceId], references: [id])

  createdAt    DateTime @default(now())
}
model Color {
  id                 String   @id @default(uuid())
  name               String
  hex                String
  category           String
  undertone          String   @default("neutral")
  lighteningLevel    String   @default("none")
  suitableFor        String   @default("light,medium,dark")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
}
model SalonSettings {
  id               String @id @default(uuid())
  activeStaffCount Int    @default(3)
}